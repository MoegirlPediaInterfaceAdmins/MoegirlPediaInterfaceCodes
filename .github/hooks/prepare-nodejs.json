{
    "version": 1,
    "hooks": {
        "sessionStart": [
            {
                "type": "command",
                "bash": "if [[ \"${GITHUB_ACTIONS}\" == \"true\" ]]; then sudo n lts && hash -r; fi",
                "timeoutSec": 137
            }
        ],
        "preToolUse": [
            {
                "type": "command",
                "bash": "node --version",
                "timeoutSec": 137
            }
        ]
    }
}
