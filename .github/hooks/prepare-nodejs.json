{
    "version": 1,
    "hooks": {
        "SessionStart": [
            {
                "type": "command",
                "linux": "if [ \"${GITHUB_ACTIONS}\" = \"true\" ]; then sudo n lts >/dev/null && hash -r; else :; fi && printf '%s\\n' '{\"continue\":true}'",
                "osx": "if [ \"${GITHUB_ACTIONS}\" = \"true\" ]; then sudo n lts >/dev/null && hash -r; else :; fi && printf '%s\\n' '{\"continue\":true}'",
                "timeout": 137
            }
        ],
        "PreToolUse": [
            {
                "type": "command",
                "linux": "node -p 'JSON.stringify({continue:true,hookSpecificOutput:{hookEventName:\"PreToolUse\",additionalContext:`Node.js version: v${process.versions.node}`}})'",
                "osx": "node -p 'JSON.stringify({continue:true,hookSpecificOutput:{hookEventName:\"PreToolUse\",additionalContext:`Node.js version: v${process.versions.node}`}})'",
                "timeout": 137
            }
        ]
    }
}
